# ============================================================================
# Python ML Project .gitignore
# Comprehensive exclusion patterns for open source repository
# ============================================================================

# ----------------------------------------------------------------------------
# Python Artifacts
# ----------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# ----------------------------------------------------------------------------
# Virtual Environments
# ----------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
.virtualenv/
virtualenv/
pipenv/
.python-version

# ----------------------------------------------------------------------------
# Machine Learning Model Files
# ----------------------------------------------------------------------------
# PyTorch models
*.pt
*.pth

# ONNX models
*.onnx

# TensorFlow models
*.pb
*.h5
*.keras

# Model weights
*.weights
*.caffemodel

# Pickle files (may contain models)
*.pkl
*.pickle

# ----------------------------------------------------------------------------
# Dataset Files
# ----------------------------------------------------------------------------
datasets/
data/
raw_data/
processed_data/
*.csv
*.tsv
*.json
*.xml
*.parquet

# Image datasets
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.webp

# Video datasets
*.mp4
*.avi
*.mov
*.mkv

# ----------------------------------------------------------------------------
# Training Outputs
# ----------------------------------------------------------------------------
runs/
weights/
results/
checkpoints/
logs/
tensorboard/
wandb/
mlruns/
outputs/
experiments/

# ----------------------------------------------------------------------------
# IDE Configuration
# ----------------------------------------------------------------------------
# VSCode
.vscode/
.history/

# PyCharm
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# Sublime Text
*.sublime-project
*.sublime-workspace

# ----------------------------------------------------------------------------
# Operating System Artifacts
# ----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.directory
.Trash-*
.nfs*

# ----------------------------------------------------------------------------
# Jupyter Notebook
# ----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# ----------------------------------------------------------------------------
# Testing
# ----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
*.cover
*.py,cover
.cache
nosetests.xml
coverage.xml
*.coveragerc

# ----------------------------------------------------------------------------
# Environment Variables and Secrets
# ----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
.envrc
secrets.yaml
secrets.json

# ----------------------------------------------------------------------------
# Documentation Build
# ----------------------------------------------------------------------------
docs/_build/
docs/.doctrees/
site/
.mkdocs/

# ----------------------------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.swp
*.log

# ----------------------------------------------------------------------------
# Project Specific
# ----------------------------------------------------------------------------
# Keep models directory structure but ignore model files
models/*.pt
models/*.pth
models/*.onnx
models/*.weights

# Debug outputs
debug/
.kiro
